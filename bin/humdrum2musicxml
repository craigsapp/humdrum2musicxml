#!/usr/bin/perl
#
# Programmer:     Craig Stuart Sapp <craig@ccrma.stanford.edu>
# Creation Date:  Mon 13 Sep 2021 11:06:35 AM PDT
# Last Modified:  Mon 13 Sep 2021 11:06:38 AM PDT
# Program Name:   humdrum2musicxml
# Syntax:         PERL 5
# Usage:          humdrum2musicxml file.krn > file.musicxml
# Usage:          cat file.krn | humdrum2musicxml > file.musicxml
#
# Description:    Converts Humdrum data into MusicXML data, using
#                 conversion interface at http://data.musicxml.humdrum.org
#
# To use LWP, you may need to run this command or related:
#       perl -MCPAN -e "install Bundle::LWP;"
#       dnf install 'perl(LWP::ConsoleLogger)'
#

use strict;
use HTTP::Request::Common;
use LWP::UserAgent;

my $data;
my $line;
while ($line = <>) {
   $data .= "$line";
}

# --- FIX 1: Point directly to the script or ensure protocol matches ---
my $url = "http://musicxml.humdrum.org";

my $ua = LWP::UserAgent->new();

# --- FIX 2: Allow LWP to automatically follow redirect codes ---
$ua->requests_redirectable(['GET', 'HEAD', 'POST']);

# --- FIX 3: Correct multipart packaging for an in-memory scalar variable ---
# By passing a scalar reference (\$data) and a dummy filename ('input.krn'),
# HTTP::Request::Common packages it exactly as an uploaded browser file.
my $request = POST($url,
   Content_Type => 'form-data',
   Content      => [
      inputdata => [ undef, 'input.krn', Content => $data ]
   ]
);

# Execute request and isolate the plain message payload context
my $response = $ua->request($request);

if ($response->is_success) {
   # Print out the raw MusicXML returned from converter21
   print $response->decoded_content;
} else {
   # Output diagnostic error feedback if the pipeline breaks
   die "HTTP Error: " . $response->status_line . "\n" . $response->decoded_content . "\n";
}


